# P4 — Memory layer + product-knowledge vector search (Redis)
# Vector search (lib/knowledge) needs Redis Stack, which bundles RediSearch.
# It's a superset, so the plain memory layer works against it too.
# Local:  redis://localhost:6379   (docker run -p 6379:6379 redis/redis-stack:latest)
# Cloud:  redis://default:<password>@<host>:<port>   (Redis Cloud has Search)
REDIS_URL=redis://localhost:6379

# Product-knowledge RAG — embeddings (OpenAI). Claude does not produce embeddings.
# EMBED_DIM must match the model (text-embedding-3-small = 1536) and the index.
OPENAI_API_KEY=
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# Auth.js (NextAuth v5) — Google sign-in
# Put the real values in .env.local (gitignored), not here.
# AUTH_SECRET: generate with `npx auth secret`
# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET: from a Google Cloud OAuth 2.0 Client ID
#   (Web application). Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Voice agent + live demo room (P1/P2/P3)
# Browserbase — drives the real product in the demo room
BROWSERBASE_API_KEY=bb_live_xxxxxxxxxxxxxxxxxxxx
BROWSERBASE_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DEMO_TARGET_URL=https://worldcuparena.live/
# Anthropic — the agent "brain" (Claude). Distinct from OPENAI_API_KEY (embeddings only).
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx
