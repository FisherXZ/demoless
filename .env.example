# Copy to .env.local and fill in. Never commit a real key.
ANTHROPIC_API_KEY=
PORT=8787
# Set USE_STUB=1 to run the orchestrator with the canned model (no API key needed).
USE_STUB=

# Browserbase
BROWSERBASE_API_KEY=bb_live_xxxxxxxxxxxxxxxxxxxx
BROWSERBASE_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DEMO_TARGET_URL=https://worldcuparena.live/
DEEPGRAM_API_KEY=
VOICE_SERVER_PORT=3001

# P4 — Memory layer + product-knowledge vector search (Redis)
# Vector search (lib/knowledge) needs Redis Stack, which bundles RediSearch.
# Local:  redis://localhost:6379   (docker run -p 6379:6379 redis/redis-stack:latest)
# Cloud:  redis://default:<password>@<host>:<port>   (Redis Cloud has Search)
REDIS_URL=redis://localhost:6379

# Product-knowledge RAG — embeddings (OpenAI). Claude does not produce embeddings.
# EMBED_DIM must match the model (text-embedding-3-small = 1536) and the index.
OPENAI_API_KEY=
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
