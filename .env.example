# P4 — Memory layer (Redis)
# Local:  redis://localhost:6379   (docker run -p 6379:6379 redis:7)
# Cloud:  redis://default:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# Auth.js (NextAuth v5) — Google sign-in
# Put the real values in .env.local (gitignored), not here.
# AUTH_SECRET: generate with `npx auth secret`
# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET: from a Google Cloud OAuth 2.0 Client ID
#   (Web application). Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
